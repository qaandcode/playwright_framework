{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "commonjs",
    "lib":              ["ES2022"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "outDir":           "./dist",
    "rootDir":          "./",
    "baseUrl":          "./",
    "paths": {
      "@fixtures": ["fixtures/index.ts"],
      "@utils/*":  ["utils/*"],
      "@pages/*":  ["pages/*"],
      "@types/*":  ["types/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "fixtures/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"]
}
